{
  "extends": "@equisoft/typescript-config/tsconfig.standards.json",
  "compilerOptions": {
    "target": "ES2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "rootDir": "./stories",
    "types": [
      "node"
    ]
  },
  "include": [
    "stories", "custom.d.ts", "asset.d.ts"
  ]
}
